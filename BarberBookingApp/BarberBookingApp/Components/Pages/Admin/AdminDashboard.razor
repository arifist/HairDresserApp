@page "/admin/panel"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@inject IAppointmentService AppointmentService
@inject AppDbContext Db

<PageTitle>Yönetim Paneli | Kuaför Arif</PageTitle>

<h2 class="mb-4">Hoş Geldin, Arif</h2>

<div class="row gy-4 mb-4">
    <div class="col-md-4">
        <div class="ka-card p-4">
            <div class="ka-icon"><i class="bi bi-calendar-day"></i></div>
            <h3 class="mb-0">@todayCount</h3>
            <p class="text-muted mb-0">Bugünkü Randevu</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ka-card p-4">
            <div class="ka-icon"><i class="bi bi-calendar-week"></i></div>
            <h3 class="mb-0">@upcomingCount</h3>
            <p class="text-muted mb-0">Yaklaşan (7 Gün) Randevu</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="ka-card p-4">
            <div class="ka-icon"><i class="bi bi-people"></i></div>
            <h3 class="mb-0">@customerCount</h3>
            <p class="text-muted mb-0">Toplam Müşteri</p>
        </div>
    </div>
</div>

<div class="ka-card p-4">
    <h5 class="mb-3">Bugünün Randevuları</h5>
    @if (todayAppointments is null || todayAppointments.Count == 0)
    {
        <p class="text-muted mb-0">Bugün için planlanmış randevu bulunmuyor.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark-ka align-middle">
                <thead>
                    <tr>
                        <th>Saat</th>
                        <th>Müşteri</th>
                        <th>Telefon</th>
                        <th>Hizmet</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in todayAppointments)
                    {
                        <tr>
                            <td>@a.StartTime.ToString("HH:mm")</td>
                            <td>@a.Customer?.FullName</td>
                            <td>@a.Customer?.PhoneNumber</td>
                            <td>@a.ServiceType?.Name</td>
                            <td>
                                <span class="badge @(a.Status == AppointmentStatus.Cancelled ? "badge-cancelled" : "badge-confirmed")">
                                    @(a.Status == AppointmentStatus.Cancelled ? "İptal" : "Onaylı")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    <a href="/admin/randevular" class="btn btn-outline-gold mt-3">Tüm Randevuları Gör</a>
</div>

@code {
    private int todayCount;
    private int upcomingCount;
    private int customerCount;
    private List<Appointment>? todayAppointments;

    protected override async Task OnInitializedAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        todayAppointments = await AppointmentService.GetAllAppointmentsAsync(today);
        todayCount = todayAppointments.Count(a => a.Status != AppointmentStatus.Cancelled);

        var now = DateTime.Now;
        var weekAhead = now.AddDays(7);
        upcomingCount = await Db.Appointments.CountAsync(a =>
            a.Status != AppointmentStatus.Cancelled && a.StartTime >= now && a.StartTime <= weekAhead);

        customerCount = await Db.Customers.CountAsync();
    }
}
