@page "/admin/giris"

<PageTitle>Admin Girişi | Kuaför Arif</PageTitle>

<section class="ka-section">
    <div class="container" style="max-width:420px;">
        <div class="ka-form-card">
            <h3 class="text-center mb-1"><i class="bi bi-shield-lock text-gold"></i></h3>
            <h4 class="text-center mb-4">Yönetim Paneli Girişi</h4>

            @if (Error == "1")
            {
                <div class="alert alert-danger small">Kullanıcı adı veya şifre hatalı.</div>
            }

            <form method="post" action="/api/auth/admin-login">
                <input type="hidden" name="returnUrl" value="@(string.IsNullOrWhiteSpace(ReturnUrl) ? "/admin/panel" : ReturnUrl)" />
                <div class="mb-3">
                    <label class="form-label">Kullanıcı Adı</label>
                    <input type="text" name="username" class="form-control" required autofocus />
                </div>
                <div class="mb-3">
                    <label class="form-label">Şifre</label>
                    <input type="password" name="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-gold w-100">Giriş Yap</button>
            </form>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }
}
