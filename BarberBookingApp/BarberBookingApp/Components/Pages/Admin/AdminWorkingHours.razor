@page "/admin/calisma-saatleri"
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject AppDbContext Db

<PageTitle>Çalışma Saatleri | Kuaför Arif Admin</PageTitle>

<h2 class="mb-2">Çalışma Saatleri</h2>
<p class="text-muted mb-4">
    Burada belirlediğiniz saat aralıkları, müşterilerin randevu alırken görebileceği müsait zaman dilimlerini doğrudan belirler.
</p>

@if (saved)
{
    <div class="alert alert-success">Çalışma saatleri güncellendi.</div>
}

@if (hours is null)
{
    <p class="text-muted">Yükleniyor...</p>
}
else
{
    <div class="ka-card p-4">
        @foreach (var wh in hours)
        {
            <div class="row align-items-center py-2 border-bottom" style="border-color: var(--ka-border) !important;">
                <div class="col-4 col-md-3 fw-semibold">@TurkceGun(wh.DayOfWeek)</div>
                <div class="col-3 col-md-2">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" @bind="wh.IsOpen" />
                        <label class="form-check-label small">@(wh.IsOpen ? "Açık" : "Kapalı")</label>
                    </div>
                </div>
                <div class="col-5 col-md-3">
                    <input type="time" class="form-control form-control-sm" disabled="@(!wh.IsOpen)"
                           value="@wh.StartTime.ToString(@"hh\:mm")"
                           @onchange="e => wh.StartTime = ParseTime(e.Value)" />
                </div>
                <div class="col-12 col-md-1 text-center text-muted d-none d-md-block">—</div>
                <div class="col-5 col-md-3 mt-2 mt-md-0">
                    <input type="time" class="form-control form-control-sm" disabled="@(!wh.IsOpen)"
                           value="@wh.EndTime.ToString(@"hh\:mm")"
                           @onchange="e => wh.EndTime = ParseTime(e.Value)" />
                </div>
            </div>
        }
        <button class="btn btn-gold mt-4" @onclick="Save" disabled="@saving">
            @(saving ? "Kaydediliyor..." : "Kaydet")
        </button>
    </div>
}

@code {
    private List<WorkingHour>? hours;
    private bool saving;
    private bool saved;

    protected override async Task OnInitializedAsync()
    {
        hours = await Db.WorkingHours
            .OrderBy(w => w.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)w.DayOfWeek)
            .ToListAsync();
    }

    private async Task Save()
    {
        saving = true;
        await Db.SaveChangesAsync();
        saving = false;
        saved = true;
    }

    private static TimeSpan ParseTime(object? value)
    {
        return TimeSpan.TryParse(value?.ToString(), out var t) ? t : TimeSpan.Zero;
    }

    private static string TurkceGun(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Pazartesi",
        DayOfWeek.Tuesday => "Salı",
        DayOfWeek.Wednesday => "Çarşamba",
        DayOfWeek.Thursday => "Perşembe",
        DayOfWeek.Friday => "Cuma",
        DayOfWeek.Saturday => "Cumartesi",
        DayOfWeek.Sunday => "Pazar",
        _ => day.ToString()
    };
}
