@page "/giris"
@rendermode InteractiveServer
@inject IOtpService OtpService
@inject AppDbContext Db

<PageTitle>Giriş Yap | Kuaför Arif</PageTitle>

<section class="ka-section">
    <div class="container" style="max-width:480px;">
        <div class="ka-form-card">
            <h3 class="text-center mb-1">Giriş Yap</h3>
            <p class="text-muted text-center mb-4">Telefon numaranızla SMS doğrulama kodu alın</p>

            @if (Error == "name-required")
            {
                <div class="alert alert-warning small">Yeni üyelik için lütfen ad soyad bilgisini de girin.</div>
            }
            else if (Error == "invalid-code")
            {
                <div class="alert alert-danger small">Girdiğiniz kod geçersiz veya süresi dolmuş. Lütfen tekrar deneyin.</div>
            }

            @if (!codeSent)
            {
                <div class="mb-3">
                    <label class="form-label">Telefon Numarası</label>
                    <input type="tel" class="form-control" @bind="phoneNumber" placeholder="05XX XXX XX XX" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Ad Soyad <span class="text-muted small">(yeni üyelik için)</span></label>
                    <input type="text" class="form-control" @bind="fullName" placeholder="Adınız Soyadınız" />
                </div>
                @if (!string.IsNullOrEmpty(requestError))
                {
                    <div class="alert alert-danger small">@requestError</div>
                }
                <button class="btn btn-gold w-100" @onclick="RequestCode" disabled="@requesting">
                    @(requesting ? "Gönderiliyor..." : "Doğrulama Kodu Gönder")
                </button>
            }
            else
            {
                @if (!string.IsNullOrEmpty(testCode))
                {
                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle me-1"></i>
                        Test modu: SMS hesabı henüz tanımlanmadığı için kodunuz burada gösteriliyor: <strong>@testCode</strong>
                    </div>
                }
                <p class="text-muted small mb-3">
                    <strong>@phoneNumber</strong> numarasına gönderilen 6 haneli kodu girin.
                </p>
                <form method="post" action="/api/auth/verify-otp">
                    <input type="hidden" name="phoneNumber" value="@phoneNumber" />
                    <input type="hidden" name="fullName" value="@fullName" />
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />
                    <div class="mb-3">
                        <label class="form-label">Doğrulama Kodu</label>
                        <input type="text" name="code" class="form-control text-center" maxlength="6" inputmode="numeric" placeholder="------" required />
                    </div>
                    <button type="submit" class="btn btn-gold w-100">Doğrula ve Giriş Yap</button>
                </form>
                <button class="btn btn-link w-100 mt-2 text-muted" @onclick="() => codeSent = false">
                    Numarayı değiştir
                </button>
            }
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Phone { get; set; }

    private string phoneNumber = string.Empty;
    private string fullName = string.Empty;
    private bool codeSent;
    private bool requesting;
    private string? requestError;
    private string? testCode;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Phone))
        {
            phoneNumber = Phone;
        }
    }

    private async Task RequestCode()
    {
        requestError = null;
        testCode = null;

        if (string.IsNullOrWhiteSpace(phoneNumber) || phoneNumber.Where(char.IsDigit).Count() < 10)
        {
            requestError = "Lütfen geçerli bir telefon numarası girin.";
            return;
        }

        requesting = true;
        var result = await OtpService.RequestCodeAsync(phoneNumber.Trim());
        requesting = false;

        if (!result.Success)
        {
            requestError = result.ErrorMessage;
            return;
        }

        codeSent = true;

        var lastLog = await Db.SmsLogs
            .Where(l => l.PhoneNumber == phoneNumber.Trim() && l.Provider.StartsWith("Simulated"))
            .OrderByDescending(l => l.SentAt)
            .FirstOrDefaultAsync();

        if (lastLog is not null)
        {
            var match = System.Text.RegularExpressions.Regex.Match(lastLog.Message, @"\d{6}");
            if (match.Success)
            {
                testCode = match.Value;
            }
        }
    }
}
