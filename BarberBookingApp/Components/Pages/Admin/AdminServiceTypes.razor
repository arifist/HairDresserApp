@page "/admin/hizmetler"
@layout AdminLayout
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject JsonDataStore Store

<PageTitle>Hizmetler | Kuaför Arif Admin</PageTitle>

<h2 class="mb-2">Hizmetler</h2>
<p class="text-muted mb-4">
    Hizmet sürelerini buradan değiştirebilirsiniz; süre değişiklikleri yeni alınacak randevuların saat aralıklarına anında yansır.
</p>

@if (saved)
{
    <div class="alert alert-success">Değişiklikler kaydedildi.</div>
}

@if (services is null)
{
    <p class="text-muted">Yükleniyor...</p>
}
else
{
    <div class="ka-card p-4 mb-4">
        <div class="table-responsive">
            <table class="table table-dark-ka align-middle">
                <thead>
                    <tr>
                        <th>Ad</th>
                        <th style="width:110px;">Süre (dk)</th>
                        <th style="width:120px;">Fiyat (₺)</th>
                        <th style="width:90px;">Aktif</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in services)
                    {
                        <tr>
                            <td><input class="form-control form-control-sm" @bind="s.Name" /></td>
                            <td><input type="number" min="1" max="480" class="form-control form-control-sm" @bind="s.DurationMinutes" /></td>
                            <td><input type="number" min="0" class="form-control form-control-sm" @bind="s.Price" /></td>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" @bind="s.IsActive" />
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <button class="btn btn-gold mt-2" @onclick="Save" disabled="@saving">
            @(saving ? "Kaydediliyor..." : "Değişiklikleri Kaydet")
        </button>
    </div>

    <div class="ka-card p-4">
        <h5 class="mb-3">Yeni Hizmet Ekle</h5>
        <div class="row gy-2">
            <div class="col-md-4">
                <input class="form-control" placeholder="Hizmet Adı" @bind="newName" />
            </div>
            <div class="col-md-2">
                <input type="number" min="1" max="480" class="form-control" placeholder="Süre (dk)" @bind="newDuration" />
            </div>
            <div class="col-md-2">
                <input type="number" min="0" class="form-control" placeholder="Fiyat (₺)" @bind="newPrice" />
            </div>
            <div class="col-md-4">
                <button class="btn btn-outline-gold w-100" @onclick="AddService" disabled="@string.IsNullOrWhiteSpace(newName)">
                    <i class="bi bi-plus-circle me-1"></i>Ekle
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ServiceType>? services;
    private bool saving;
    private bool saved;
    private string newName = string.Empty;
    private int newDuration = 30;
    private decimal newPrice;

    protected override void OnInitialized()
    {
        LoadServices();
    }

    private void LoadServices()
    {
        services = Store.ServiceTypes.OrderBy(s => s.SortOrder).ToList();
    }

    private async Task Save()
    {
        saving = true;
        await Store.UpdateServiceTypesAsync();
        saving = false;
        saved = true;
    }

    private async Task AddService()
    {
        if (string.IsNullOrWhiteSpace(newName)) return;
        var maxSort = services?.Count > 0 ? services.Max(s => s.SortOrder) : 0;
        await Store.AddServiceTypeAsync(new ServiceType
        {
            Name = newName.Trim(),
            DurationMinutes = newDuration <= 0 ? 30 : newDuration,
            Price = newPrice,
            IsActive = true,
            SortOrder = maxSort + 1,
            Icon = "bi-stars"
        });
        newName = string.Empty;
        newDuration = 30;
        newPrice = 0;
        LoadServices();
    }
}
